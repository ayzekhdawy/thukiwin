{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThukiWin",
  "version": "0.1.0",
  "identifier": "com.thukiwin.thukiwin",
  "build": {
    "beforeDevCommand": "bun run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ThukiWin",
        "width": 600,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: asset: https://asset.localhost; media-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
